@model MathTime.Models.User

@{
    ViewData["Title"] = "Редактирование пользователя";
}

<style>
    .edit-wrapper {
        max-width: 500px;
        margin: 40px auto;
        padding: 30px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        text-align: center;
        animation: fadeIn 0.5s ease;
    }

        .edit-wrapper h2 {
            margin-bottom: 20px;
            font-size: 1.8rem;
        }

    .form-group {
        margin-bottom: 15px;
        text-align: left;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 5px;
    }

    .form-control {
        width: 100%;
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #ccc;
        box-sizing: border-box;
    }

    .btn {
        width: 100%;
        padding: 10px 16px;
        border: none;
        border-radius: 8px;
        color: #fff;
        cursor: pointer;
        font-size: 1rem;
        margin-top: 10px;
        background-color: #6f42c1;
    }

        .btn:hover {
            background-color: #5936a2;
        }
</style>

<div class="edit-wrapper">
    <h2>Редактировать пользователя</h2>

    <form method="post" action="/admin/edit/@Model.Id">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Имя</label>
            <input class="form-control" type="text" name="FirstName" value="@Model.FirstName" required />
        </div>

        <div class="form-group">
            <label>Фамилия</label>
            <input class="form-control" type="text" name="LastName" value="@Model.LastName" required />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input class="form-control" type="email" name="Email" value="@Model.Email" required />
        </div>

        <div class="form-group">
            <label>Телефон</label>
            <input class="form-control" type="text" name="Phone" value="@Model.Phone" />
        </div>

        <div class="form-group">
            <label>Дата рождения</label>
            <input class="form-control" type="date" name="DateOfBirth" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
        </div>

        <div class="form-group">
            <label>Пол</label>
            <select class="form-control" name="Gender">
                <option value="Male" selected="@(Model.Gender == "Male")">Мужской</option>
                <option value="Female" selected="@(Model.Gender == "Female")">Женский</option>
                <option value="" selected="@(string.IsNullOrEmpty(Model.Gender))">Не указан</option>
            </select>
        </div>

        <div class="form-group">
            <label>Роль</label>
            <select class="form-control" name="Role">
                <option value="User" selected="@(Model.Role == "User")">Пользователь</option>
                <option value="Admin" selected="@(Model.Role == "Admin")">Админ</option>
            </select>
        </div>

        <button type="submit" class="btn">Сохранить изменения</button>
    </form>
</div>

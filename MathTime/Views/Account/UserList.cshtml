@model List<MathTime.Models.User>

@{
    ViewData["Title"] = "Панель администратора - Пользователи";
}

<style>
    .admin-wrapper {
        max-width: 900px;
        margin: 40px auto;
        padding: 20px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 10px;
        text-align: left;
        border-bottom: 1px solid #eee;
    }

    th {
        background: #f8f8f8;
    }

    .btn {
        padding: 6px 12px;
        border: none;
        border-radius: 8px;
        color: #fff;
        cursor: pointer;
        font-size: 0.9rem;
        text-decoration: none;
        display: inline-block;
        min-width: 90px;
        text-align: center;
    }

    .btn-edit {
        background: #6f42c1;
    }

        .btn-edit:hover {
            background: #5936a2;
        }

    .btn-delete {
        background: #d9534f;
    }

        .btn-delete:hover {
            background: #c9302c;
        }

    .btn-block {
        background: #f0ad4e;
    }

        .btn-block:hover {
            background: #ec971f;
        }

    .btn-unblock {
        background: #0d6efd;
    }

        .btn-unblock:hover {
            background: #0b5ed7;
        }
</style>

<div class="admin-wrapper">
    <h2>Управление пользователями</h2>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Имя</th>
                <th>Email</th>
                <th>Роль</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.FirstName @user.LastName</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>@(user.IsBlocked ? "Заблокирован" : "Активен")</td>
                    <td>
                        <a href="/admin/edit/@user.Id" class="btn btn-edit">Редактировать</a>

                        <form method="post" action="/admin/delete/@user.Id" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-delete" onclick="return confirm('Удалить пользователя?')">Удалить</button>
                        </form>

                        @if (!user.IsBlocked)
                        {
                            <form method="post" action="/admin/block/@user.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-block">Заблокировать</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" action="/admin/unblock/@user.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-unblock">Разблокировать</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

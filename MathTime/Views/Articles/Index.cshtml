@model IEnumerable<MathTime.Models.Article>
@using System.Security.Claims
@{
    ViewData["Title"] = "Статьи";

    string currentRole = User.FindFirstValue(ClaimTypes.Role) ?? "";
    string userIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
    int currentUserId = 0;

    if (!string.IsNullOrEmpty(userIdStr))
    {
        currentUserId = int.Parse(userIdStr);
    }

    bool isAdmin = string.Equals(currentRole, "Admin", StringComparison.OrdinalIgnoreCase);
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    .emoji-panel {
        overflow-x: auto;
        white-space: nowrap;
    }

        .emoji-panel button {
            display: inline-block;
            margin-right: 2px;
        }

    .modal-header .btn-close.btn-sm {
        width: 1rem;
        height: 1rem;
    }

    .comment {
        padding: 0.5rem;
        border-bottom: 1px solid #eee;
        position: relative;
    }

    .comment-actions {
        position: absolute;
        right: 5px;
        top: 5px;
    }

    .modal-custom-width {
        max-width: 95% !important;
    }

    .modal-body {
        max-height: 80vh;
        overflow-y: auto;
    }

    .editor-toolbar button {
        margin-right: 5px;
    }

    #articleContentEditable, #editArticleContentEditable {
        min-height: 150px;
        max-height: 300px;
        overflow-y: auto;
        border: 1px solid #ced4da;
        padding: 0.375rem 0.75rem;
        border-radius: 0.375rem;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Список статей</h1>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createArticleModal">➕ Создать статью</button>
    </div>

    <ul id="articleList" class="list-group">
        @foreach (var article in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center" data-id="@article.Id">
                <div><strong>@article.Title</strong> — <em>@article.Author</em></div>
                <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-info" onclick="openArticleModal(@article.Id)">Просмотр</button>
                    @if (isAdmin || article.AuthorId == currentUserId)
                    {
                        <button class="btn btn-sm btn-primary" onclick="openEditArticleModal(@article.Id)">Редактировать</button>
                        <button class="btn btn-sm btn-danger" onclick="deleteArticle(@article.Id)">Удалить</button>
                    }
                </div>
            </li>
        }
    </ul>
</div>

<!-- ===== МОДАЛКА: ПРОСМОТР СТАТЬИ ===== -->
<div class="modal fade" id="viewArticleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-custom-width">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="viewTitle" class="modal-title">Просмотр статьи</h5>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-1"><small id="viewAuthor"></small></p>
                <div id="viewContent" class="mb-3"></div>

                <div class="mb-3">
                    <button id="likeBtn" class="btn btn-sm btn-outline-primary">❤️ Лайк (<span id="likeCount">0</span>)</button>
                </div>

                <div class="mb-3">
                    <h6>Комментарии</h6>
                    <div class="mb-1 emoji-panel">
                        @foreach (var emoji in new[] { "😃", "😄", "😁", "😆", "😂", "😍", "🥰", "😎", "🤩", "😢", "😭", "😡", "🤔", "😴", "👍", "👎", "🎉", "💡", "❤️", "💔", "🔥" })
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addEmoji('@emoji')">@emoji</button>
                        }
                    </div>
                    <div id="commentsList" style="max-height: 300px; overflow-y: auto;"></div>
                    <textarea id="commentInput" class="form-control mb-2" rows="2" placeholder="Написать комментарий..."></textarea>
                    <button id="commentBtn" class="btn btn-sm btn-success">Отправить</button>
                    <div class="text-danger mt-1 d-none" id="commentError">Комментарий не может быть пустым</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== МОДАЛКА: СОЗДАНИЕ СТАТЬИ ===== -->
<div class="modal fade" id="createArticleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form id="createArticleForm" asp-controller="Articles" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Создать статью</h5>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input name="Title" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Содержание</label>
                        <div class="editor-toolbar mb-2">
                            <button type="button" onclick="format('bold')" class="btn btn-sm btn-outline-secondary"><b>B</b></button>
                            <button type="button" onclick="format('italic')" class="btn btn-sm btn-outline-secondary"><i>I</i></button>
                            <button type="button" onclick="format('underline')" class="btn btn-sm btn-outline-secondary"><u>U</u></button>
                            <button type="button" onclick="format('insertUnorderedList')" class="btn btn-sm btn-outline-secondary">• List</button>
                            <button type="button" onclick="format('insertOrderedList')" class="btn btn-sm btn-outline-secondary">1. List</button>
                            <button type="button" onclick="format('createLink', prompt('Введите URL:'))" class="btn btn-sm btn-outline-secondary">🔗 Link</button>
                            <input type="color" onchange="format('foreColor', this.value)" class="btn btn-sm p-0" style="width:30px;height:30px;" />
                            <select onchange="format('fontSize', this.value)" class="form-select form-select-sm d-inline-block w-auto ms-1">
                                <option value="1">Очень маленький</option>
                                <option value="2">Маленький</option>
                                <option value="3" selected>Средний</option>
                                <option value="4">Большой</option>
                                <option value="5">Очень большой</option>
                                <option value="6">Огромный</option>
                                <option value="7">Максимальный</option>
                            </select>
                            <button type="button" onclick="insertImage()" class="btn btn-sm btn-outline-secondary">🖼️ Img</button>
                        </div>
                        <div id="articleContentEditable" contenteditable="true"></div>
                        <input type="hidden" name="Content" id="articleContentHidden" />
                    </div>
                    <div class="alert alert-danger d-none" id="createErrors"></div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-success" type="submit">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ===== МОДАЛКА: РЕДАКТИРОВАНИЕ СТАТЬИ ===== -->
<div class="modal fade" id="editArticleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form id="editArticleForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Редактировать статью</h5>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editArticleId" name="id" />
                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input id="editArticleTitle" name="title" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Содержание</label>
                        <div class="editor-toolbar mb-2">
                            <button type="button" onclick="formatEdit('bold')" class="btn btn-sm btn-outline-secondary"><b>B</b></button>
                            <button type="button" onclick="formatEdit('italic')" class="btn btn-sm btn-outline-secondary"><i>I</i></button>
                            <button type="button" onclick="formatEdit('underline')" class="btn btn-sm btn-outline-secondary"><u>U</u></button>
                            <button type="button" onclick="formatEdit('insertUnorderedList')" class="btn btn-sm btn-outline-secondary">• List</button>
                            <button type="button" onclick="formatEdit('insertOrderedList')" class="btn btn-sm btn-outline-secondary">1. List</button>
                            <button type="button" onclick="formatEdit('createLink', prompt('Введите URL:'))" class="btn btn-sm btn-outline-secondary">🔗 Link</button>
                            <input type="color" onchange="formatEdit('foreColor', this.value)" class="btn btn-sm p-0" style="width:30px;height:30px;" />
                            <select onchange="formatEdit('fontSize', this.value)" class="form-select form-select-sm d-inline-block w-auto ms-1">
                                <option value="1">Очень маленький</option>
                                <option value="2">Маленький</option>
                                <option value="3" selected>Средний</option>
                                <option value="4">Большой</option>
                                <option value="5">Очень большой</option>
                                <option value="6">Огромный</option>
                                <option value="7">Максимальный</option>
                            </select>
                            <button type="button" onclick="insertImageEdit()" class="btn btn-sm btn-outline-secondary">🖼️ Img</button>
                        </div>
                        <div id="editArticleContentEditable" contenteditable="true"></div>
                        <input type="hidden" id="editArticleContentHidden" name="content" />
                    </div>
                    <div class="alert alert-danger d-none" id="editErrors"></div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-success" type="submit">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    let currentArticleId = null;
    const isAdmin = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(isAdmin));
    const currentUserId = @currentUserId;

    // ===== РЕДАКТОР =====
    function format(cmd,val=null){document.execCommand(cmd,false,val);}
    function insertImage(){const url=prompt("Введите URL изображения:"); if(url) format('insertImage',url);}
    function formatEdit(cmd,val=null){document.execCommand(cmd,false,val);}
    function insertImageEdit(){const url=prompt("Введите URL изображения:"); if(url) formatEdit('insertImage',url);}

    // ===== ПРОСМОТР СТАТЬИ =====
    function openArticleModal(id){
        currentArticleId=id;
        fetch(`/Articles/GetArticle/${id}`)
            .then(r=>r.ok?r.json():Promise.reject("Не удалось загрузить статью"))
            .then(a=>{
                document.getElementById("viewTitle").textContent=a.title;
                document.getElementById("viewAuthor").textContent="Автор: "+a.author;
                document.getElementById("viewContent").innerHTML=a.content;
                document.getElementById("likeCount").textContent=a.likes;

                const commentsList=document.getElementById("commentsList");
                commentsList.innerHTML="";

                a.comments.forEach(c=>{
                    const canEditOrDelete = isAdmin || c.userId===currentUserId;
                    const div=document.createElement("div");
                    div.className="comment";
                    div.id=`comment-${c.id}`;
                    div.innerHTML=`<strong>${c.userName}</strong>: <span class="comment-text">${c.content}</span> <small class="text-muted">${c.createdAt}</small>`;
                    if(canEditOrDelete){
                        const actions=document.createElement("div");
                        actions.className="comment-actions";
                        actions.innerHTML=`<button class="btn btn-sm btn-primary" onclick="editComment(${c.id})">Редактировать</button>
                                           <button class="btn btn-sm btn-danger" onclick="deleteComment(${c.id})">Удалить</button>`;
                        div.appendChild(actions);
                    }
                    commentsList.appendChild(div);
                });

                document.getElementById("commentInput").value="";
                document.getElementById("commentError").classList.add("d-none");
                new bootstrap.Modal(document.getElementById("viewArticleModal")).show();
            })
            .catch(err=>alert(err));
    }

    // ===== ЛАЙК =====
    document.getElementById("likeBtn").addEventListener("click",()=>{
        if(!currentArticleId) return;
        const fd=new FormData();
        fd.append("articleId",currentArticleId);
        fd.append("__RequestVerificationToken",document.querySelector('input[name="__RequestVerificationToken"]').value);

        fetch(`/Articles/Like`,{method:"POST",body:fd})
            .then(r=>r.json())
            .then(res=>{if(res.success) document.getElementById("likeCount").textContent=res.count;});
    });

    // ===== КОММЕНТАРИИ =====
    document.getElementById("commentBtn").addEventListener("click",()=>{
        const content=document.getElementById("commentInput").value.trim();
        if(!content){document.getElementById("commentError").classList.remove("d-none"); return;}
        document.getElementById("commentError").classList.add("d-none");

        const fd=new FormData();
        fd.append("articleId",currentArticleId);
        fd.append("content",content);
        fd.append("__RequestVerificationToken",document.querySelector('input[name="__RequestVerificationToken"]').value);

        fetch(`/Articles/AddComment`,{method:"POST",body:fd})
            .then(r=>r.ok?r.json():r.json().then(err=>Promise.reject(err)))
            .then(res=>{
                if(res.success){
                    const commentsList=document.getElementById("commentsList");
                    const c=res.comment;
                    const div=document.createElement("div");
                    div.className="comment";
                    div.id=`comment-${c.id}`;
                    let actionsHtml="";
                    if(isAdmin || currentUserId===c.userId){
                        actionsHtml=`<div class="comment-actions">
                                        <button class="btn btn-sm btn-primary" onclick="editComment(${c.id})">Редактировать</button>
                                        <button class="btn btn-sm btn-danger" onclick="deleteComment(${c.id})">Удалить</button>
                                     </div>`;
                    }
                    div.innerHTML=`<strong>${c.userName}</strong>: <span class="comment-text">${c.content}</span> <small class="text-muted">${c.createdAt}</small> ${actionsHtml}`;
                    commentsList.appendChild(div);
                    document.getElementById("commentInput").value="";
                }
            })
            .catch(err=>alert(err?.error || "Ошибка добавления комментария"));
    });

    function addEmoji(emoji){
        const ta=document.getElementById("commentInput");
        const start=ta.selectionStart,end=ta.selectionEnd;
        ta.value = ta.value.substring(0,start)+emoji+ta.value.substring(end);
        ta.selectionStart=ta.selectionEnd=start+emoji.length;
        ta.focus();
    }

    // ===== РЕДАКТИРОВАНИЕ СТАТЬИ =====
    function openEditArticleModal(id){
        fetch(`/Articles/GetArticle/${id}`)
            .then(r=>r.ok?r.json():Promise.reject("Не удалось загрузить статью"))
            .then(article=>{
                document.getElementById("editArticleId").value=article.id;
                document.getElementById("editArticleTitle").value=article.title;
                document.getElementById("editArticleContentEditable").innerHTML=article.content;
                new bootstrap.Modal(document.getElementById("editArticleModal")).show();
            })
            .catch(err=>alert(err));
    }

    document.getElementById("editArticleForm").addEventListener("submit",function(e){
        e.preventDefault();
        const editor=document.getElementById("editArticleContentEditable");
        const hidden=document.getElementById("editArticleContentHidden");
        const errors=document.getElementById("editErrors");
        hidden.value=editor.innerHTML.trim();
        if(!hidden.value){errors.classList.remove("d-none"); errors.textContent="Введите содержание статьи"; return;}
        const formData=new FormData(this);
        fetch("/Articles/EditArticle",{method:"POST",body:formData})
            .then(r=>r.ok?r.json():r.json().then(err=>Promise.reject(err)))
            .then(res=>{if(res.success) location.reload();})
            .catch(err=>{errors.classList.remove("d-none"); errors.textContent=err?.error||"Ошибка редактирования";});
    });

    // ===== УДАЛЕНИЕ СТАТЬИ =====
    function deleteArticle(articleId){
        if(!confirm("Удалить статью?")) return;
        const fd=new FormData();
        fd.append("id",articleId);
        fd.append("__RequestVerificationToken",document.querySelector('input[name="__RequestVerificationToken"]').value);
        fetch("/Articles/DeleteArticle",{method:"POST",body:fd})
            .then(r=>r.json())
            .then(res=>{if(res.success) document.querySelector(`#articleList li[data-id='${articleId}']`).remove();})
            .catch(err=>alert("Ошибка удаления статьи"));
    }

    // ===== СОЗДАНИЕ СТАТЬИ =====
    document.getElementById("createArticleForm").addEventListener("submit",function(e){
        e.preventDefault();
        const editor=document.getElementById("articleContentEditable");
        const hidden=document.getElementById("articleContentHidden");
        const errors=document.getElementById("createErrors");
        hidden.value=editor.innerHTML.trim();
        if(!hidden.value){errors.classList.remove("d-none"); errors.textContent="Введите содержание статьи"; return;}
        const formData=new FormData(this);
        fetch("/Articles/Create",{method:"POST",body:formData})
            .then(r=>r.ok?r.json():r.json().then(err=>Promise.reject(err)))
            .then(res=>{if(res.success) location.reload();})
            .catch(err=>{errors.classList.remove("d-none"); errors.textContent="Ошибка создания статьи";});
    });

    // ===== КОММЕНТАРИИ =====
    function editComment(commentId){
        const div=document.getElementById(`comment-${commentId}`);
        const span=div.querySelector(".comment-text");
        const oldText=span.textContent;

        const input=document.createElement("input");
        input.type="text";
        input.value=oldText;
        input.className="form-control form-control-sm d-inline-block w-75 me-2";

        div.replaceChild(input,span);

        const saveBtn=document.createElement("button");
        saveBtn.className="btn btn-sm btn-success me-1";
        saveBtn.textContent="Сохранить";
        saveBtn.onclick=()=>saveCommentEdit(commentId,input.value);

        const cancelBtn=document.createElement("button");
        cancelBtn.className="btn btn-sm btn-secondary";
        cancelBtn.textContent="Отмена";
        cancelBtn.onclick=()=>{
            div.replaceChild(span,input);
            saveBtn.remove();
            cancelBtn.remove();
        };

        const actions=div.querySelector(".comment-actions");
        actions.prepend(saveBtn);
        actions.prepend(cancelBtn);
    }

    function saveCommentEdit(commentId,newContent){
        if(!newContent.trim()) return alert("Комментарий не может быть пустым");
        const fd=new FormData();
        fd.append("id",commentId);
        fd.append("content",newContent);
        fd.append("__RequestVerificationToken",document.querySelector('input[name="__RequestVerificationToken"]').value);
        fetch(`/Articles/EditComment`,{method:"POST",body:fd})
            .then(r=>r.ok?r.json():r.json().then(err=>Promise.reject(err)))
            .then(res=>{
                if(res.success){
                    const div=document.getElementById(`comment-${commentId}`);
                    const input=div.querySelector("input");
                    const span=document.createElement("span");
                    span.className="comment-text";
                    span.textContent=newContent;
                    div.replaceChild(span,input);
                    const actions=div.querySelector(".comment-actions");
                    actions.innerHTML=`<button class="btn btn-sm btn-primary" onclick="editComment(${commentId})">Редактировать</button>
                                       <button class="btn btn-sm btn-danger" onclick="deleteComment(${commentId})">Удалить</button>`;
                }
            })
            .catch(err=>alert("Ошибка редактирования комментария"));
    }

    function deleteComment(commentId){
        if(!confirm("Удалить комментарий?")) return;
        const fd=new FormData();
        fd.append("id",commentId);
        fd.append("__RequestVerificationToken",document.querySelector('input[name="__RequestVerificationToken"]').value);
        fetch(`/Articles/DeleteComment`,{method:"POST",body:fd})
            .then(r=>r.json())
            .then(res=>{if(res.success) document.getElementById(`comment-${commentId}`).remove();})
            .catch(err=>alert("Ошибка удаления комментария"));
    }
</script>

<script>
    // --- Модальные окна ---
    function openLogin() {
        const modal = document.getElementById('loginModal');
        modal.style.display = 'flex';
        modal.querySelector('.modal-content').classList.add('show');
    }
    function closeLogin() {
        const modal = document.getElementById('loginModal');
        modal.querySelector('.modal-content').classList.remove('show');
        setTimeout(()=> modal.style.display = 'none', 300);
    }

    function openRegister() {
        const modal = document.getElementById('registerModal');
        modal.style.display = 'flex';
        modal.querySelector('.modal-content').classList.add('show');
    }
    function closeRegister() {
        const modal = document.getElementById('registerModal');
        modal.querySelector('.modal-content').classList.remove('show');
        setTimeout(()=> modal.style.display = 'none', 300);
    }

    function openWhatsappModal() {
        const modal = document.getElementById("whatsappModal");
        modal.style.display = "flex";
        modal.querySelector('.wa-modal-content').classList.add('show');
    }
    function closeWhatsappModal() {
        const modal = document.getElementById("whatsappModal");
        modal.querySelector('.wa-modal-content').classList.remove('show');
        setTimeout(()=> modal.style.display = 'none', 300);
    }

    function openChatModal() {
        const modal = document.getElementById("chatModal");
        modal.style.display = "flex";
        modal.querySelector('.wa-modal-content').classList.add('show');
    }
    function closeChatModal() {
        const modal = document.getElementById("chatModal");
        modal.querySelector('.wa-modal-content').classList.remove('show');
        setTimeout(()=> modal.style.display = 'none', 300);
    }

    // --- Чат-бот с эффектом печати ---
    async function sendMessage() {
        const input = document.getElementById('chatInput');
        const message = input.value.trim();
        if(!message) return;

        const chatBox = document.getElementById('chatMessages');
        chatBox.innerHTML += `<div><strong>Вы:</strong> ${message}</div>`;
        input.value = '';
        chatBox.scrollTop = chatBox.scrollHeight;

        try {
            const response = await fetch('/Home/ChatBot', {
                method: 'POST',
                headers: { 'Content-Type':'application/json' },
                body: JSON.stringify({ message })
            });
            const data = await response.json();

            // Эффект печати
            const botDiv = document.createElement('div');
            botDiv.innerHTML = "<strong>Бот:</strong> <span class='typing'></span>";
            chatBox.appendChild(botDiv);

            const typingSpan = botDiv.querySelector('.typing');
            let i = 0;
            const text = data.response;
            const interval = setInterval(() => {
                typingSpan.textContent += text[i];
                i++;
                chatBox.scrollTop = chatBox.scrollHeight;
                if(i >= text.length) clearInterval(interval);
            }, 20); // скорость печати: 20мс на символ

        } catch (error) {
            chatBox.innerHTML += `<div><strong>Бот:</strong> Ошибка сервера.</div>`;
        }
    }

    // --- Закрытие модальных окон при клике на фон ---
    window.addEventListener('click', function(event) {
        if(event.target == document.getElementById('loginModal')) closeLogin();
        if(event.target == document.getElementById('registerModal')) closeRegister();
        if(event.target == document.getElementById('whatsappModal')) closeWhatsappModal();
        if(event.target == document.getElementById('chatModal')) closeChatModal();
    });

    // --- Автооткрытие модальных окон при ошибках ---
    @if (TempData["LoginError"] != null)
    {
        <text>openLogin();</text>
    }
    @if (TempData["RegisterError"] != null)
    {
        <text>openRegister();</text>
    }
</script>






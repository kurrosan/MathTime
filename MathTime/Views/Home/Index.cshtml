@using System.Security.Claims
@{
    ViewData["Title"] = "Главная";

    var mathQuotes = new string[]
    {
        "Математика — царица наук, а арифметика — царица математики. — К. Ф. Гаусс",
        "Математика — это язык, на котором написана книга природы. — Галилео Галилей",
        "Чистая математика — это поэзия логики. — Альберт Эйнштейн",
        "Математика — это способ думать ясно. — Исаак Ньютон",
        "В математике мы не знаем, что ищем, пока не найдём. — Анри Пуанкаре"
    };

    var random = new Random();
    var randomQuote = mathQuotes[random.Next(mathQuotes.Length)];
}

<!-- Модальное окно Входа -->
<div id="loginModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeLogin()">&times;</span>
        <h2>Вход в аккаунт</h2>
        @if (TempData["LoginError"] != null)
        {
            <p style="color:red">@TempData["LoginError"]</p>
        }
        <form method="post" action="/login">
            @Html.AntiForgeryToken()
            <label for="emailLogin">Email:</label>
            <input type="email" id="emailLogin" name="Email" required value="@TempData["LoginEmail"]" />
            <label for="passwordLogin">Пароль:</label>
            <input type="password" id="passwordLogin" name="Password" required />
            <button type="submit">Войти</button>
        </form>
    </div>
</div>

<!-- Модальное окно Регистрации -->
<div id="registerModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeRegister()">&times;</span>
        <h2>Создать аккаунт</h2>
        @if (TempData["RegisterError"] != null)
        {
            <p style="color:red">@TempData["RegisterError"]</p>
        }
        <form method="post" action="/register" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <label for="firstName">Имя:</label>
            <input type="text" id="firstName" name="FirstName" required />
            <label for="lastName">Фамилия:</label>
            <input type="text" id="lastName" name="LastName" required />
            <label for="phone">Телефон:</label>
            <input type="tel" id="phone" name="Phone" required />
            <label for="dob">Дата рождения:</label>
            <input type="date" id="dob" name="DateOfBirth" required />
            <label for="gender">Пол:</label>
            <select id="gender" name="Gender" required>
                <option value="">Выберите...</option>
                <option value="Male">Мужской</option>
                <option value="Female">Женский</option>
            </select>
            <label for="emailRegister">Email:</label>
            <input type="email" id="emailRegister" name="Email" required />
            <label for="passwordRegister">Пароль:</label>
            <input type="password" id="passwordRegister" name="Password" required />
            <label for="confirmPasswordRegister">Подтвердите пароль:</label>
            <input type="password" id="confirmPasswordRegister" name="ConfirmPassword" required />
            <label for="avatar">Фото профиля:</label>
            <input type="file" id="avatar" name="Avatar" accept="image/*" />
            <button type="submit">Зарегистрироваться</button>
        </form>
    </div>
</div>

<!-- Основной контент -->
<div class="content">
    <p>Приветствуем вас! На нашем сайте обучение математике становится увлекательным и продуктивным благодаря совместным усилиям.</p>
    <ul class="feature-list">
        <li>📝 <strong>Обменивайтесь опытом:</strong> делитесь методиками, заданиями и лайфхаками.</li>
        <li>🤝 <strong>Находите поддержку:</strong> задавайте вопросы и решайте задачи вместе с сообществом.</li>
        <li>🎓 <strong>Участвуйте в событиях:</strong> вебинары, мастер-классы, челленджи и многое другое.</li>
    </ul>
    <p>Присоединяйтесь к нам, чтобы сделать математику доступной и интересной для всех!</p>
    <div style="margin-top:20px; text-align:center;">
        <button class="wa-btn" onclick="openWhatsappModal()">Присоединяйтесь к нам Вконтакте 🤍</button>


    <div>
        <br></br>
</div>
        <div style="margin-top:20px; padding:20px 25px; border-radius:16px; background:linear-gradient(135deg,#eef2ff,#e0e7ff); box-shadow:0 8px 20px rgba(0,0,0,0.1); text-align:center; font-family:Arial, sans-serif;">

            <h2 style="color:#2563eb; font-size:1.8em; margin-bottom:15px;">
                🛠 Техническая поддержка MathTime
            </h2>

            <p style="color:#374151; font-size:1em; line-height:1.6; margin-bottom:15px;">
                Возникли вопросы при работе с платформой? Виртуальный помощник поможет быстро получить ответы по использованию сайта, загрузке материалов, работе со статьями, авторизации и другим функциям системы.
            </p>

            <ul style="list-style:none; padding-left:0; margin-bottom:20px; text-align:left; display:inline-block;">
                <li style="margin:8px 0; font-size:1em;">
                    ✅ Помощь при регистрации и входе в аккаунт.
                </li>

                <li style="margin:8px 0; font-size:1em;">
                    ✅ Подсказки по загрузке и скачиванию файлов.
                </li>

                <li style="margin:8px 0; font-size:1em;">
                    ✅ Консультации по публикации и редактированию статей.
                </li>

                <li style="margin:8px 0; font-size:1em;">
                    ✅ Ответы на частые вопросы пользователей.
                </li>

                <li style="margin:8px 0; font-size:1em;">
                    ✅ Поддержка пользователей 24/7.
                </li>
            </ul>

            <p style="color:#374151; font-size:1em; line-height:1.6;">
                Система технической поддержки создана для того, чтобы сделать использование цифрового ресурса максимально удобным и понятным для каждого пользователя.
            </p>

            <button class="chat-btn"
                    onclick="openChatModal()"
                    style="margin-top:15px; background:linear-gradient(90deg,#2563eb,#7c3aed); color:white; font-weight:600; font-size:16px; padding:12px 25px; border:none; border-radius:12px; cursor:pointer;">
                Открыть поддержку 💬
            </button>

        </div>
        <div>
            <br></br>
        </div>
        
    </div>
</div>

<aside>
    <div class="card">
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="user-card">
                <img src="/avatar/@User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier)" alt="Аватар" />
                <p>Привет, <span class="user-name">@User.FindFirst("FirstName")?.Value</span> <span class="user-surname">@User.FindFirst("LastName")?.Value</span>!</p>
                <form method="post" action="/logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn">Выйти</button>
                </form>
            </div>
        }
        else
        {
            <div class="auth-links">
                <a id="loginBtn" class="login-btn" href="javascript:void(0)" onclick="openLogin()">Вход</a>
                <a id="registerBtn" class="register-btn" href="javascript:void(0)" onclick="openRegister()">Регистрация</a>
            </div>
        }
    </div>

    <div class="card">
        <h2>Новости</h2>
        <ul>
            <li>🆕 Новые методические материалы уже доступны</li>
            <li>📅 Вебинар "Математика в жизни" — 3 августа</li>
            <li>🛠 Обновили дизайн платформы</li>
        </ul>
    </div>

    <div class="card">
        <h2>Цитата дня</h2>
        <p class="italic">«@randomQuote»</p>
    </div>
</aside>

<!-- Модальное окно ВКонтакте -->
<div id="whatsappModal" class="wa-modal">
    <div class="wa-modal-content">
        <span class="wa-close" onclick="closeWhatsappModal()">&times;</span>
        <h2>Присоединяйтесь к нам Вконтакте ❤️</h2>
        <p>Отсканируйте QR-код или нажмите кнопку ниже:</p>
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=https://vk.me/join/F4eDS0eMj_U3mbE2GgADxxiAsaXQdCnrWI4=" alt="QR Вконтакте">
        <a href="https://vk.me/join/F4eDS0eMj_U3mbE2GgADxxiAsaXQdCnrWI4=" target="_blank">
            <button class="wa-action-btn">Написать в Вконтакте</button>
        </a>
    </div>
</div>

<!-- Модальное окно чат-бота -->
<div id="chatModal" class="wa-modal">
    <div class="wa-modal-content">
        <span class="wa-close" onclick="closeChatModal()">&times;</span>
        <h2 style="text-align:center; color:#4f46e5;">Синусик — ваш помощник 🤖</h2>
        <div id="chatMessages"></div>
        <div style="display:flex; gap:8px; margin-top:10px;">
            <input type="text" id="chatInput" placeholder="Введите сообщение..." />
            <button onclick="sendMessage()">Отправить</button>
        </div>
    </div>
</div>

